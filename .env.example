# --- 모델 (필수) ---
# OpenRouter API 키 (OpenAI 호환)
OPENAI_API_KEY=

# --- 웹 검색 커넥터 (선택) ---
# 있으면 Tavily 웹 검색 도구가 자동 활성화된다.
TAVILY_API_KEY=
SMITHERY_API_KEY=

# --- Slack 커넥터 (선택) ---
# 쓰기용 Bot User OAuth Token (xoxb-...). Bot Token Scope: chat:write
SLACK_BOT_TOKEN=
# 읽기용 User OAuth Token (xoxp-...). 봇 초대 없이 내가 속한 (비)공개 채널 열람.
# User Token Scope: channels:history, groups:history, channels:read, groups:read
# 한쪽만 넣으면 그 토큰으로 읽기·쓰기를 모두 처리한다.
SLACK_USER_TOKEN=
# (게이트웨이 수신용) App-Level Token (xapp-...). Socket Mode 활성화 + scope connections:write.
# 이벤트 구독: app_mention, message.im. Slack 에서 봇을 멘션/DM 하면 에이전트가 답한다.
SLACK_APP_TOKEN=

# --- Telegram 커넥터 (선택) ---
# @BotFather 로 발급한 봇 토큰
TELEGRAM_BOT_TOKEN=
# 기본 수신 대상 chat_id (telegram_send_message 의 chat_id 를 비우면 이 값을 사용)
TELEGRAM_CHAT_ID=

# --- Email 커넥터 (선택, 일반 SMTP/IMAP) ---
# 에이전트 '도구'로만 동작(게이트웨이 자동응답 아님): read_recent_emails / send_email
# Gmail 예: SMTP smtp.gmail.com:587, IMAP imap.gmail.com:993, 앱 비밀번호 사용
# 발신 (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
# 수신 (IMAP) — USER/PASSWORD 미설정 시 SMTP_USER/PASSWORD 를 재사용
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# --- 작업 공간 (선택) ---
# 에이전트 파일/셸 작업이 이뤄지는 디렉터리 
WORKSPACE_DIR=workspace
