{
  "_설명": "이 파일은 형식 예시입니다. 실제로 쓰려면 mcp_servers.json 에 아래 형태로 서버를 채우세요. (이 example 파일은 로드되지 않습니다.)",

  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
    "transport": "stdio"
  },

  "notion-local": {
    "command": "npx",
    "args": ["-y", "@notionhq/notion-mcp-server"],
    "env": { "NOTION_API_KEY": "여기에-키" },
    "transport": "stdio"
  },

  "notion-smithery": {
    "url": "https://mcp.smithery.run/yunseong9048",
    "headers": { "Authorization": "Bearer ${SMITHERY_API_KEY}" },
    "transport": "streamable_http"
  },

  "github": {
    "url": "https://api.githubcopilot.com/mcp/",
    "transport": "streamable_http"
  }
}
